{
  "git": {
    "commitMessage": "chore: release v${version}",
    "tagName": "v${version}",
    "tagAnnotation": "Release v${version}"
  },
  "npm": {
    "publish": false
  },
  "github": {
    "release": false
  },
  "hooks": {
    "after:bump": "echo 'Version bumped to ${version}'",
    "after:release": "bash scripts/post-release.sh"
  }
}
