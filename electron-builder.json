{
  "appId": "io.github.ligeon",
  "productName": "Ligeon",
  "directories": {
    "buildResources": "resources",
    "output": "release"
  },
  "files": [
    "dist/**/*",
    "dist-electron/**/*",
    "package.json"
  ],
  "artifactName": "ligeon-${version}-installer-${arch}.${ext}",
  "asar": true,
  "asarUnpack": [
    "**/node_modules/better-sqlite3/**",
    "**/node_modules/bindings/**",
    "**/node_modules/file-uri-to-path/**"
  ],
  "mac": {
    "target": ["dmg"],
    "category": "public.app-category.games",
    "icon": "resources/icons/mac/icon.icns",
    "notarize": true
  },
  "win": {
    "target": ["nsis"],
    "icon": "resources/icons/win/icon.ico"
  },
  "linux": {
    "target": ["AppImage"],
    "icon": "resources/icons/png/icon.png",
    "category": "Game"
  }
}
