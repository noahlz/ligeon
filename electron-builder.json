{
  "appId": "io.github.ligeon",
  "productName": "Ligeon",
  "directories": {
    "buildResources": "resources",
    "output": "out"
  },
  "files": [
    "dist/**/*",
    "dist-electron/**/*",
    "package.json"
  ],
  "mac": {
    "target": ["dmg"],
    "category": "public.app-category.games",
    "icon": "resources/icons/mac/icon.icns"
  },
  "win": {
    "target": ["nsis"],
    "icon": "resources/icons/win/icon.ico"
  },
  "linux": {
    "icon": "resources/icons/png/icon.png"
  }
}
