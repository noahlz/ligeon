{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "noEmit": false,
    "baseUrl": "..",
    "paths": {
      "@/*": ["./src/*"],
    },
    "outDir": "../dist",
    "incremental": true,
    "tsBuildInfoFile": "../dist/.tsbuildinfo"
  },
  "include": ["./**/*"]
}