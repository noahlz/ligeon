{
  "compilerOptions": {
    /* Basic Options */
    "target": "ES2020",
    "module": "NodeNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    
    /* Error Reporting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    
    /* React Support */
    "jsx": "react-jsx",
    
    /* Build & Paths */
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@shared": ["../shared/index.ts"],
      "@shared/*": ["../shared/*"]
    }
  },
  "include": [
    "./**/*", 
    "../shared/**/*"
  ],
  "exclude": [
    "node_modules"
  ]
}