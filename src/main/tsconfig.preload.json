{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist-electron",
    "rootDir": ".",
    "sourceMap": true,
    "module": "CommonJS",
    "moduleResolution": "Node",
    "tsBuildInfoFile": "../../dist-electron/.tsbuildinfo.preload",
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": ["preload.ts"],
  "exclude": ["node_modules"]
}
