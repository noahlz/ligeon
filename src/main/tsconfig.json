{
  "compilerOptions": {
    /* Basic Options */
    "target": "ES2020",
    "module": "NodeNext",
    "lib": ["ES2020"],
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    
    /* Error Reporting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "sourceMap": true,

    /* Build & Paths */
    "noEmit": false,
    /* rootDir points to 'src' so it can encompass both 'main' and 'shared' */
    "rootDir": "..",
    /* outDir: rootDir is src/, so main/main.ts -> dist-electron/main/main.js */
    "outDir": "../../dist-electron",
    "incremental": true,
    "tsBuildInfoFile": "../../dist-electron/.tsbuildinfo",
    
    "baseUrl": "."
  },
  "include": [
    "./**/*.ts", 
    "../shared/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "preload.ts"
  ]
}