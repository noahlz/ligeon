  "image": "https://noahlz.github.io/ligeon/og-image.png",
  "author": {
    "@type": "Person",
    "name": "noahlz",
    "url": "https://github.com/noahlz"
  },
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
}
