---
layout: layout.njk
---

{# GitHub corner ribbon — github-fork-ribbon-css #}
<a class="github-fork-ribbon" href="https://github.com/noahlz/ligeon" data-ribbon="Fork me on GitHub" title="Fork me on GitHub">
  Fork me on GitHub
</a>

{# ── Hero ───────────────────────────────────────────────── #}
<section class="hero">
  <h1 class="hero-title">Ligeon</h1>
  <p class="hero-tagline">Browse and replay chess games from PGN databases</p>
  <img
    class="hero-screenshot"
    src="/ligeon-screen.png"
    alt="Ligeon application screenshot showing a chess board with game notation"
    width="650"
  />
</section>

{# ── Downloads ──────────────────────────────────────────── #}
<section class="downloads">
  {% if release.version %}
    <h2 class="downloads-heading">Download v{{ release.version }}</h2>
    <div class="download-buttons">
      {% if release.mac %}
        <a class="btn-download" href="{{ release.mac.url }}" download="{{ release.mac.filename }}">
          <svg class="btn-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
          <span class="btn-platform">macOS</span>
        </a>
      {% endif %}
      {% if release.win %}
        <a class="btn-download" href="{{ release.win.url }}" download="{{ release.win.filename }}">
          <svg class="btn-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M0 3.449L9.75 2.1v9.451H0m10.949-9.602L24 0v11.4H10.949M0 12.6h9.75v9.451L0 20.699M10.949 12.6H24V24l-12.9-1.801"/></svg>
          <span class="btn-platform">Windows</span>
        </a>
      {% endif %}
      {% if release.linux %}
        <a class="btn-download" href="{{ release.linux.url }}" download="{{ release.linux.filename }}">
          <svg class="btn-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>
          <span class="btn-platform">Linux</span>
        </a>
      {% endif %}
    </div>
  {% else %}
    <p class="downloads-fallback">
      No release found yet. Check the
      <a href="https://github.com/noahlz/ligeon/releases" target="_blank" rel="noopener">
        GitHub Releases page
      </a>
      for the latest downloads.
    </p>
  {% endif %}
</section>

{# ── Features ───────────────────────────────────────────── #}
<section class="features">
  <div class="feature-cards">
    <div class="feature-card">
      <h3>Import PGN</h3>
      <p>Load game collections from plain-text PGN files</p>
    </div>
    <div class="feature-card">
      <h3>Replay Games</h3>
      <p>Step through games move by move</p>
    </div>
    <div class="feature-card">
      <h3>Annotate</h3>
      <p>Add comments, annotations and variations</p>
    </div>
    <div class="feature-card">
      <h3>View on Lichess</h3>
      <p>Export to <a href="https://lichess.org" target="_blank" rel="noopener">lichess.org</a> for engine analysis</p>
    </div>
  </div>
</section>

{# ── Lichess Attribution Medallion ──────────────────────── #}
<section class="attribution">
  <div class="medallion">
    <svg class="medallion-logo" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 50 50" width="20" height="20" aria-hidden="true"><path fill="#fff" stroke="#fff" stroke-linejoin="round" d="M38.956.5c-3.53.418-6.452.902-9.286 2.984C5.534 1.786-.692 18.533.68 29.364 3.493 50.214 31.918 55.785 41.329 41.7c-7.444 7.696-19.276 8.752-28.323 3.084S-.506 27.392 4.683 17.567C9.873 7.742 18.996 4.535 29.03 6.405c2.43-1.418 5.225-3.22 7.655-3.187l-1.694 4.86 12.752 21.37c-.439 5.654-5.459 6.112-5.459 6.112-.574-1.47-1.634-2.942-4.842-6.036-3.207-3.094-17.465-10.177-15.788-16.207-2.001 6.967 10.311 14.152 14.04 17.663 3.73 3.51 5.426 6.04 5.795 6.756 0 0 9.392-2.504 7.838-8.927L37.4 7.171z"/></svg>
    <span class="medallion-text">Built with <a href="https://lichess.org/source" target="_blank" rel="noopener">Lichess open&#8209;source components</a></span>
  </div>
</section>

{# ── Footer ─────────────────────────────────────────────── #}
<footer class="site-footer">
  <a href="https://github.com/noahlz/ligeon#readme" target="_blank" rel="noopener">View README</a>
  <span class="footer-sep">&bull;</span>
  <span>GPLv3</span>
</footer>
