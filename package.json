{
  "name": "Ligeon",
  "version": "0.2.5",
  "type": "module",
  "description": "Browse and replay chess games from PGN databases",
  "repository": "https://github.com/noahlz/ligeon",
  "author": "Noah Zucker",
  "license": "GPL-3.0",
  "main": "dist-electron/main/main.js",
  "homepage": "./",
  "scripts": {
    "clean": "rimraf dist dist-electron release .logs coverage",
    "app": "npm run build:main && npm run rebuild:electron && concurrently \"vite\" \"wait-on http://localhost:5173 && ELECTRON_IS_DEV=true electron .\"",
    "dev": "npm run app",
    "rebuild:sqlite": "npm rebuild better-sqlite3 --ignore-scripts=false",
    "rebuild:electron": "electron-rebuild -f -w better-sqlite3",
    "test": "npm run rebuild:sqlite && vitest run; CODE=$?; npm run rebuild:electron || CODE=$?; exit $CODE",
    "test:watch": "npm run rebuild:sqlite && vitest run --watch; CODE=$?; npm run rebuild:electron || CODE=$?; exit $CODE",
    "test:coverage": "npm run rebuild:sqlite && vitest run --coverage; CODE=$?; npm run rebuild:electron || CODE=$?; exit $CODE",
    "build:renderer": "tsc -p src/renderer/tsconfig.json && vite build",
    "build:main": "tsc -p src/main/tsconfig.json && tsc -p src/main/tsconfig.preload.json",
    "build": "npm run build:renderer && npm run build:main",
    "package": "npm run build && npm run rebuild:electron && electron-builder",
    "typecheck": "tsc -p src/renderer/tsconfig.json --noEmit && tsc -p src/main/tsconfig.json --noEmit && tsc -p src/main/tsconfig.preload.json --noEmit",
    "lint": "eslint src/ --max-warnings 0",
    "lint:fix": "eslint src/ --fix",
    "check": "npm run lint && npm run typecheck && npm run knip && npm run test:coverage",
    "pgn-to-sqlite": "npm run rebuild:sqlite && tsx scripts/pgn-to-sqlite.ts",
    "knip": "knip",
    "release": "release-it"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@radix-ui/react-context-menu": "2.2.16",
    "better-sqlite3": "^12.6.0",
    "chessops": "^0.15.0",
    "update-electron-app": "3.1.2",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@lichess-org/chessground": "^9.9.0",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^24.10.10",
    "@types/path-browserify": "^1.0.3",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "concurrently": "^9.1.2",
    "driver.js": "^1.4.0",
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12",
    "eslint": "^9.39.3",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "happy-dom": "^20.7.0",
    "knip": "^5.83.0",
    "lucide-react": "^0.562.0",
    "path-browserify": "^1.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "release-it": "^19.2.4",
    "rimraf": "^6.1.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "text-title-case": "^1.2.10",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vitest": "^3.2.4",
    "wait-on": "^8.0.1"
  }
}
