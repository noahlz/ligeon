{
  "name": "Ligeon",
  "version": "0.1.0",
  "type": "module",
  "description": "Browse and replay chess games from PGN databases",
  "author": "",
  "license": "GPL-3.0",
  "main": "dist-electron/main/main.js",
  "homepage": "./",
  "scripts": {
    "clean": "rimraf dist dist-electron out .logs coverage",
    "app": "npm run build:main && npm run rebuild:electron && concurrently \"vite\" \"wait-on http://localhost:5173 && ELECTRON_IS_DEV=true electron .\"",
    "rebuild:sqlite": "rm -rf node_modules/better-sqlite3/build && npm rebuild better-sqlite3",
    "rebuild:electron": "electron-rebuild -f -w better-sqlite3",
    "test": "npm run rebuild:sqlite && vitest run; npm run rebuild:electron",
    "test:watch": "npm run rebuild:sqlite && vitest run --watch; npm run rebuild:electron",
    "test:coverage": "npm run rebuild:sqlite && vitest run --coverage; npm run rebuild:electron",
    "build:renderer": "tsc -p src/renderer/tsconfig.json && vite build",
    "build:main": "tsc -p src/main/tsconfig.json && tsc -p src/main/tsconfig.preload.json",
    "build": "npm run build:renderer && npm run build:main",
    "package": "npm run build && electron-builder",
    "typecheck": "tsc -p src/renderer/tsconfig.json --noEmit && tsc -p src/main/tsconfig.json --noEmit && tsc -p src/main/tsconfig.preload.json --noEmit",
    "pgn-to-sqlite": "npm run rebuild:sqlite && tsx scripts/pgn-to-sqlite.ts"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@lichess-org/chessground": "^9.9.0",
    "better-sqlite3": "^12.6.0",
    "chessops": "^0.15.0",
    "lucide-react": "^0.562.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^24.10.0",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12",
    "electron-rebuild": "^3.2.9",
    "happy-dom": "^15.0.0",
    "postcss": "^8.4.49",
    "prebuild-install": "^7.1.3",
    "rimraf": "^6.1.2",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^3.2.4",
    "wait-on": "^8.0.1"
  }
}
