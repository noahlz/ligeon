{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "jsx": "react-jsx",
    "noEmit": true,
    "baseUrl": "..",
    "paths": {
      "@/*": ["src/renderer/*"]
    },
    "types": ["vitest/globals", "vite/client"]
  },
  "include": [
    "./**/*",
    "../src/renderer/**/*",
    "../src/shared/**/*"
  ]
}
